# Laravel core
/vendor/
/node_modules/

# Environment files
.env
.env.local
.env.*.local
!.env.example
!.env.docker

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log
storage/logs/*
!storage/logs/.gitignore
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Cache
bootstrap/cache/*
!bootstrap/cache/.gitignore
storage/framework/cache/*
!storage/framework/cache/.gitignore
storage/framework/sessions/*
!storage/framework/sessions/.gitignore
storage/framework/views/*
!storage/framework/views/.gitignore

# Testing
.phpunit.result.cache
coverage/
.phpunit/

# Build artifacts
public/build/
public/hot
dist/
build/

# Database
database/database.sqlite
database/*.db

# Backup files
backups/
*.backup

# Uploaded files (keep structure, ignore content)
storage/app/private/*
!storage/app/private/.gitignore
storage/app/public/*
!storage/app/public/.gitignore

# MinIO/S3 local storage
storage/app/minio/*

# Horizon
horizon.lock

# Telescope
telescope/

# Sentry
.sentryclirc

# Vite
vite.config.js.timestamp-*
vite.config.*.timestamp-*

# Playwright
playwright-report/
test-results/
tests/e2e/screenshots/

# k6
*.har

# Local development
docker-compose.override.yml
docker-compose.local.yml

# SSL certificates
docker/nginx/ssl/*.pem
docker/nginx/ssl/*.key

# Temporary files
tmp/
temp/
.cache/

# Composer
composer.lock

# NPM
yarn.lock

# Translations
resources/lang/*/messages.php

# Seeders (if contains sensitive data)
database/seeders/TestSeeder.php
database/factories/TestFactory.php
