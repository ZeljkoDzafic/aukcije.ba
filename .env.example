# ===================================
# AUKCIJSKA PLATFORMA - ENVIRONMENT
# ===================================
# Copy this file to .env and fill in your values
# php artisan key:generate after copying

# -----------------------------------
# APPLICATION
# -----------------------------------
APP_NAME=Aukcije
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Locale
APP_LOCALE=bs
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=bs_BA

# Timezone
APP_TIMEZONE=Europe/Sarajevo

# -----------------------------------
# LOGGING
# -----------------------------------
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------
# DATABASE (PostgreSQL 16+)
# -----------------------------------
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=aukcije
DB_USERNAME=aukcije
DB_PASSWORD=secret
DB_SSL=false

# -----------------------------------
# REDIS (Cache + Locks + Queue)
# -----------------------------------
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DATABASE=0

# -----------------------------------
# WEBSOCKET (Laravel Reverb)
# -----------------------------------
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# Echo configuration
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# -----------------------------------
# MEILISEARCH (Full-text Search)
# -----------------------------------
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=
MEILISEARCH_PREFIX=aukcije_

# -----------------------------------
# SESSION
# -----------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

# -----------------------------------
# MAIL (Transactional Emails)
# -----------------------------------
MAIL_MAILER=log
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@aukcije.ba"
MAIL_FROM_NAME="${APP_NAME}"

# Mailgun (recommended for production)
MAILGUN_DOMAIN=
MAILGUN_SECRET=
MAILGUN_ENDPOINT=api.mailgun.net

# -----------------------------------
# SMS NOTIFICATIONS (Infobip/Twilio)
# -----------------------------------
SMS_DRIVER=log
INFOBIP_API_KEY=
INFOBIP_BASE_URL=https://<instance-id>.api.infobip.com
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# -----------------------------------
# PUSH NOTIFICATIONS (Firebase)
# -----------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS=

# -----------------------------------
# FILE STORAGE (AWS S3 + CloudFront)
# -----------------------------------
FILESYSTEM_DISK=local
# local = local storage, s3 = AWS S3

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=aukcije-images
AWS_BUCKET_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

# CloudFront CDN
CLOUDFRONT_URL=

# -----------------------------------
# PAYMENT GATEWAYS
# -----------------------------------

# Stripe (International - EUR/USD)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=eur

# Monri (BiH - BAM)
MONRI_KEY=
MONRI_AUTHENTICITY_TOKEN=
MONRI_WEBHOOK_SECRET=
MONRI_CURRENCY=BAM

# CorvusPay (Croatia - EUR)
CORVUSPAY_STORE_ID=
CORVUSPAY_SECRET_KEY=
CORVUSPAY_WEBHOOK_SECRET=
CORVUSPAY_CURRENCY=eur

# -----------------------------------
# SHIPPING COURIERS
# -----------------------------------

# EuroExpress
EUROEXPRESS_API_KEY=
EUROEXPRESS_BASE_URL=

# PostExpress
POSTEXPRESS_API_KEY=
POSTEXPRESS_BASE_URL=

# BH Posta
BHPOSTA_API_KEY=
BHPOSTA_BASE_URL=

# -----------------------------------
# MONITORING & ERROR TRACKING
# -----------------------------------

# Sentry (Error tracking + Performance)
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_PROFILES_SAMPLE_RATE=0.1

# -----------------------------------
# SECURITY
# -----------------------------------

# Rate limiting overrides (optional)
RATE_LIMIT_LOGIN=5
RATE_LIMIT_API=100
RATE_LIMIT_BIDS=10

# MFA (2FA) settings
MFA_REQUIRED_FOR_SELLERS=true

# -----------------------------------
# FEATURE FLAGS
# -----------------------------------
# Enable/disable features without code deployment
FEATURE_PROXY_BIDDING=true
FEATURE_ANTI_SNIPING=true
FEATURE_ESCROW=true
FEATURE_RATINGS=true
FEATURE_DISPUTES=true
FEATURE_WALLET=true
FEATURE_STRIPE=true
FEATURE_MONRI=true
FEATURE_CORVUSPAY=true
FEATURE_EUROEXPRESS=true
FEATURE_POSTEXPRESS=true
